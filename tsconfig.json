{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "isolatedModules": true,
    "allowJs": false
  },
  "include": [
    "srv/**/*.ts",
    "db/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "gen",
    "app"
  ]
}